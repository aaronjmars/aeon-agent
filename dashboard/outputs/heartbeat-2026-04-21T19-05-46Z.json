    "action_main": {
      "type": "Text",
      "props": {
        "text": "Add a fine-grained PAT (or classic PAT) with 'workflows' scope as a GitHub Actions secret (e.g. WORKFLOWS_PAT)"
      },
      "children": []
    },
    "action_example": {
      "type": "Text",
      "props": {
        "text": "Until then, any skill that edits workflow files will open a PR that stalls at the auto-merge gate.",
