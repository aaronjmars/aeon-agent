      "type": "Text",
      "props": {
        "text": "Any skill that edits workflow files will open a PR that stalls at the auto-merge gate, requiring manual review and merge instead of autonomous completion."
      },
      "children": []
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "action_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
