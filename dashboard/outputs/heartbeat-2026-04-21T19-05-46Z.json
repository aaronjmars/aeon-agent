      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "escalation_badge",
        "timeline_text"
      ]
    },
    "escalation_badge": {
      "type": "Badge",
      "props": {
        "text": "Day 5 Escalation",
        "variant": "destructive"
      },
      "children": []
    },
    "timeline_text": {
      "type": "Text",
      "props": {
        "text": "Flagged every 48 hours since April 17, 2026",
        "variant": "muted"
      },
      "children": []
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
