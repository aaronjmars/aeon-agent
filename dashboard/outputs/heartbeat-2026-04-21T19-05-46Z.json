        "alert",
        "sep1",
        "timeline_section",
        "sep2",
        "impact_section",
        "sep3",
        "action_section"
      ]
    },
    "alert": {
      "type": "Alert",
      "props": {
        "type": "error",
        "title": "PAT with 'workflows' Scope Unresolved",
