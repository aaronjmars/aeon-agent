      "props": {
        "text": "fetch-tweets returned FETCH_TWEETS_EMPTY on every run for 4+ consecutive days because it never read from .xai-cache/fetch-tweets.json — even though the prefetch script already cached X.AI results there before Claude starts.",
        "variant": "body"
      },
      "children": []
